    "@types/typescript": "^2.0.0",
    "rivetkit": "^2.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.1"
  },
  "type": "module"
