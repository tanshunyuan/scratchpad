{
  "name": "pi-webui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"server,client\" --prefix-colors \"cyan,green\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client",
    "build:client": "vite build",
    "start": "tsx server/index.ts",
    "preview": "npm run build && npm run start"
  },
  "dependencies": {
    "@mariozechner/mini-lit": "^0.2.1",
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@mariozechner/pi-web-ui": "^0.66.1",
    "express": "^5.1.0",
    "lit": "^3.3.1",
    "lucide": "^0.544.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vite": "^7.1.6"
  }
}
